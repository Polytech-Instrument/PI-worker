PORT=3080
PUBLIC_BASE_URL=http://localhost:3080

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_USE_POLLING=true

# Google Apps Script endpoint from the Figma plugin flow.
GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/AKfycbz1xx79FIY_AbpUWNM88s4Ma6clo4JLXhcKX2agHm2zvyLCdQgpZDVJ0h6CS0cy6UGN/exec
DEFAULT_GOOGLE_GID=

# Product data. Default points to the current Figma plugin catalog.
PRODUCT_DB_PATH=../Figma-plugins/allProducts.json

# Files
OUTPUT_DIR=./output

# Images endpoint / proxy
PRODUCT_IMAGE_ENDPOINT=https://ptech.ru/getproductimage.php
IMAGE_PROXY_BASE=https://figma-proxy-1.onrender.com/img?url=
